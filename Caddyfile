{$DOMAIN} {
    # The service is mounted at /pdf_comp. Visiting the apex sends users
    # to the right place; everything else under the domain returns 404
    # so the apex stays clean for whatever you put there next.
    @root path /
    redir @root /pdf_comp/ 302

    handle /pdf_comp* {
        reverse_proxy app:3000

        # Allow PDF uploads up to the app's hard cap (LIMITS.maxBytes is at
        # most 1 GB; the app itself rejects oversize files based on real RAM).
        request_body {
            max_size 1100MB
        }
    }

    handle {
        respond 404
    }

    encode zstd gzip
}
